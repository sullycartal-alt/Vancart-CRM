# Configuration Supabase — copier ce fichier en `.env` et remplir les valeurs
# (Projet Supabase → Settings → API)
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre-cle-anon-publique

# Optionnel : mettre à "true" pour pré-charger les 6 commerces fictifs de démo
# quand Supabase n'est pas configuré (développement local uniquement)
VITE_DEMO_DATA=false
